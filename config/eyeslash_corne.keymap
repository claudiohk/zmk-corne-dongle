#define ZMK_POINTING_DEFAULT_MOVE_VAL 1400  // 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 25   // 10

#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/rgb.h>

// Physical Left Hand typing grid
#define KEYS_L 0 1 2 3 4 5 \
               13 14 15 16 17 18 \
               28 29 30 31 32 33

// Physical Right Hand typing grid
#define KEYS_R 8 9 10 11 12 \
               22 23 24 25 26 27 \
               36 37 38 39 40 41

// Center cluster (Joystick and Middle Keys) plus all Thumbs
#define KEYS_T 6 7 19 20 21 35 45 \
               34 42 43 44 46 47

#define C_HM_L(k1, k2, k3, k4) &c_hm_l LGUI k1 &c_hm_l LALT k2 &c_hm_l LCTRL k3 &c_hm_l LSHFT k4
#define C_HM_R(k1, k2, k3, k4) &c_hm_r RSHFT k1 &c_hm_r RCTRL k2 &c_hm_r RALT k3 &c_hm_r RGUI k4

&mmv_input_listener { input-processors = <&zip_xy_scaler 2 1>; };

&msc_input_listener { input-processors = <&zip_scroll_scaler 2 1>; };

&msc {
    acceleration-exponent = <1>;      // 0
    time-to-max-speed-ms = <300>;       // 300
    delay-ms = <0>;                   // 0
};

&mmv {
    time-to-max-speed-ms = <500>;
    acceleration-exponent = <2>;
    trigger-period-ms = <16>;
};

&soft_off { hold-time-ms = <2000>; };

/ {
    behaviors {
    rgb_encoder: rgb_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&rgb_ug RGB_BRI>, <&rgb_ug RGB_BRD>;
    };

    scroll_encoder: scroll_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;
        tap-ms = <100>;
    };

// Left-hand mods: Only trigger when a RIGHT or THUMB key is pressed
        c_hm_l: homerow_left_mod {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <275>;
            quick-tap-ms = <150>; 
            require-prior-idle-ms = <150>; 
            hold-trigger-key-positions = <KEYS_R KEYS_T>;
            hold-trigger-on-release; 
            bindings = <&kp>, <&kp>;
        };

// Right-hand mods: Only trigger when a LEFT or THUMB key is pressed
        c_hm_r: homerow_right_mod {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <275>;
            quick-tap-ms = <150>;
            require-prior-idle-ms = <150>;
            hold-trigger-key-positions = <KEYS_L KEYS_T>;
            hold-trigger-on-release;
            bindings = <&kp>, <&kp>;
        };
    };

    rgb_encoder: rgb_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&rgb_ug RGB_BRI>, <&rgb_ug RGB_BRD>;
    };

    scroll_encoder: scroll_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;

        tap-ms = <30>;
    };

    combos {
      compatible = "zmk,combos";
      cut {
        timeout-ms = <18>;
        bindings = <&kp K_CUT>;
        key-positions = <30 32>;
        require-prior-idle-ms = <150>;
      };
      copy {
        timeout-ms = <18>;
        bindings = <&kp K_COPY>;
        key-positions = <30 31>;
        require-prior-idle-ms = <150>;
      };
      paste {
        timeout-ms = <18>;
        bindings = <&kp K_PASTE>;
        key-positions = <31 32>;
        require-prior-idle-ms = <150>;
      };
    };

    keymap {
        compatible = "zmk,keymap";

        Base {
            display-name = "QWERTY";
            bindings = <
&kp C_PLAY_PAUSE  &kp Q           &kp W           &kp E               &kp R             &kp T                                &kp UP                &kp Y        &kp U              &kp I                &kp O            &kp P                  &kp C_MUTE
&kp C_NEXT        &c_hm_l LGUI A  &c_hm_l LALT S  &c_hm_l LCTRL D     &c_hm_l LSHFT F   &kp G                      &kp LEFT  &kp ENTER  &kp RIGHT  &kp H        &c_hm_r RSHFT J    &c_hm_r RCTRL K      &c_hm_r RALT L   &c_hm_r RGUI SEMI      &kp C_VOL_UP
&kp C_PREV        &lt 3 Z         &kp X           &kp C               &kp V             &kp B      &lt 5 C_MUTE              &kp DOWN              &kp N        &kp M              &kp COMMA            &kp DOT          &kp FSLH               &kp C_VOL_DN
                                                  &lt 4 ESC           &lt 1 SPACE       &lt 2 TAB                                                  &lt 6 ENTER  &lt 5 BACKSPACE    &lt 7 DEL
            >;

            sensor-bindings = <&inc_dec_kp C_VOLUME_UP C_VOLUME_DOWN>;
        };

        Navi {
            display-name = "Navi";
            bindings = <
&trans  &none              &trans            &trans             &trans                  &trans                            &mmv MOVE_UP                     &kp K_REDO    &kp K_PASTE  &kp K_COPY  &kp K_CUT  &kp K_UNDO  &trans
&trans  &c_hm_l LGUI A     &c_hm_l LALT S    &c_hm_l LCTRL D    &c_hm_l LSHFT F         &trans            &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &kp CAPSLOCK  &kp LEFT     &kp DOWN    &kp UP     &kp RIGHT   &trans
&trans  &trans             &trans            &trans             &trans                  &trans  &trans                    &mmv MOVE_DOWN                   &kp INSERT    &kp HOME     &kp PG_DN   &kp PG_UP  &kp END     &trans
                                             &trans             &trans                  &trans                                                             &kp ENTER     &kp BSPC     &kp DEL
            >;

            sensor-bindings = <&inc_dec_kp C_AC_ZOOM_IN C_AC_ZOOM_OUT>;
        };

        Mouse {
            display-name = "Mouse";
            bindings = <
&none   &trans        &trans        &trans            &trans          &none                             &mmv MOVE_UP                     &kp K_REDO      &kp K_PASTE     &kp K_COPY      &kp K_CUT     &kp K_UNDO       &trans
&none   &kp LGUI      &kp LALT      &kp LCTRL         &kp LSHFT       &none             &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &msc SCRL_UP    &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_UP  &mmv MOVE_RIGHT  &trans
&trans  &trans        &trans        &trans            &trans          &none   &trans                    &mmv MOVE_DOWN                   &msc SCRL_DOWN  &msc SCRL_LEFT  &msc SCRL_DOWN  &msc SCRL_UP  &msc SCRL_RIGHT  &trans
                                    &trans            &trans          &trans                                                             &mkp RCLK       &mkp LCLK       &mkp MCLK
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        Button {
            display-name = "Button";
            bindings = <
&trans  &kp K_UNDO    &kp K_CUT  &kp K_COPY  &kp K_PASTE  &kp K_REDO                            &mmv MOVE_UP                     &kp K_REDO  &kp K_PASTE      &kp K_COPY         &kp K_CUT      &kp K_UNDO     &trans
&trans  &kp LGUI      &kp LALT   &kp LCTRL   &kp LSHFT    &trans                &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &trans      &kp RSHFT        &kp RCTRL          &kp RALT       &kp RGUI       &trans
&trans  &kp K_UNDO    &kp K_CUT  &kp K_COPY  &kp K_PASTE  &kp K_REDO  &trans                    &mmv MOVE_DOWN                   &kp K_REDO  &kp K_PASTE      &kp K_COPY         &kp K_CUT      &kp K_UNDO     &trans
                                 &mkp MCLK   &mkp LCLK    &mkp RCLK                                                              &mkp RCLK   &mkp LCLK        &mkp MCLK
            >;

            sensor-bindings = <&inc_dec_kp C_AC_ZOOM_IN C_AC_ZOOM_OUT>;
        };

        Media {
            display-name = "Media";
            bindings = <
&trans  &trans        &trans        &trans            &trans          &trans                                    &kp C_FF                        &bt BT_CLR_ALL  &out OUT_USB  &out OUT_BLE       &trans             &trans            &trans
&trans  &kp LGUI      &kp LALT      &kp LCTRL         &kp LSHFT       &none                         &kp C_PREV  &kp C_PLAY_PAUSE    &kp C_NEXT  &bt BT_CLR      &kp C_PREV    &kp C_VOLUME_DOWN  &kp C_VOLUME_UP    &kp C_NEXT        &trans
&none   &none         &none         &none             &none           &none       &bt BT_CLR_ALL                &kp C_RW                        &bt BT_SEL 0    &bt BT_SEL 1  &bt BT_SEL 2       &bt BT_SEL 3       &bt BT_SEL 4      &trans
                                    &trans            &trans          &bt BT_CLR                                                                &trans          &trans        &trans
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        Num {
            display-name = "Num";
            bindings = <
&trans  &kp LBKT          &kp N7        &kp N8      &kp N9  &kp RBKT                                      &rgb_ug RGB_BRI                   &trans  &trans     &trans             &trans    &trans    &trans
&trans  &kp SEMI          &kp N4        &kp N5      &kp N6  &kp EQUAL                    &rgb_ug RGB_EFR  &rgb_ug RGB_TOG  &rgb_ug RGB_EFF  &trans  &kp RSHFT  &kp RCTRL          &kp RALT  &kp RGUI  &trans
&trans  &kp GRAVE         &kp N1        &kp N2      &kp N3  &kp BACKSLASH      &trans                     &rgb_ug RGB_BRD                   &trans  &trans     &trans             &trans    &trans    &trans
                                        &kp PERIOD  &kp N0  &kp MINUS                                                                       &trans  &trans     &trans
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        Sym {
            display-name = "Sym";
            bindings = <
&trans  &kp LBRC        &kp AMPS         &kp STAR              &kp LPAR               &kp RBRC                           &trans          &trans  &trans           &trans             &trans         &trans         &trans
&trans  &kp COLON       &kp DLLR         &kp PRCNT             &kp CARET              &kp PLUS                   &trans  &trans  &trans  &trans  &kp RSHFT        &kp RCTRL          &kp RALT       &kp RGUI       &trans
&trans  &kp TILDE       &kp EXCL         &kp AT                &kp HASH               &kp PIPE         &trans            &trans          &trans  &trans           &trans             &trans         &trans         &trans
                                         &kp LPAR              &kp RPAR               &kp UNDER                                          &trans  &trans           &trans
            >;
        };

        Fun {
            display-name = "Fun";
            bindings = <
&trans  &kp F12  &kp F7  &kp F8      &kp F9     &kp PSCRN                          &trans          &trans  &trans           &trans             &trans         &trans         &trans
&trans  &kp F11  &kp F4  &kp F5      &kp F6     &kp SLCK                   &trans  &trans  &trans  &trans  &kp RSHFT        &kp RCTRL          &kp RALT       &kp RGUI       &trans
&trans  &kp F10  &kp F1  &kp F2      &kp F3     &kp PAUSE_BREAK  &trans            &trans          &trans  &trans           &trans             &trans         &trans         &trans
                         &kp C_MENU  &kp SPACE  &kp TAB                                            &trans  &trans           &trans
            >;

        };
    };
}; 
